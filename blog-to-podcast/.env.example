# Đổi tên/copy thành file .env (cùng thư mục docker-compose.yml). Không commit .env.

# Bắt buộc khi muốn process-service gọi Gemini thật (không dùng tóm tắt giả).
GEMINI_API_KEY=

# true = cả stack dùng mock (content giả, process giả, tts giả). false = thật (process cần GEMINI_API_KEY).
USE_MOCK=false

GEMINI_MODEL=gemini-2.5-flash
