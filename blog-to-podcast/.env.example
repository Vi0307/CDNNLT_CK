# ==========================================
# CẤU HÌNH DÙNG CHUNG CHO TOÀN BỘ PROJECT
# ==========================================
# true = dùng mock. false = gọi API thật.
USE_MOCK=false

# ==========================================
# AI SERVICE - CLAUDE ONLY
# ==========================================
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://1gw.gwai.cloud
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_TIMEOUT=180

# ==========================================
# TTS SERVICE
# ==========================================
AUDIO_DIR=audio_output
# Có key thì dùng Google TTS, để trống thì fallback edge-tts.
GOOGLE_API_KEY=
